# Mot de passe admin de la Bbox, URL-encodé (voir README.md).
# Ex : le mot de passe « secret&pass?42 » s'écrit « secret%26pass%3F42 ».
BB_PASSWORD=votre_mot_de_passe_url_encode

# Optionnel — valeurs par défaut indiquées.
# BB_URL=https://mabbox.bytel.fr
# BB_REFRESH_SECONDS=60
# BB_LISTEN=0.0.0.0:9100
# Métriques par appareil : active (défaut), all ou off.
# BB_HOST_METRICS=active
